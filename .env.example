# Copy this file to your local/cloud environment configuration and replace values there.
# Do not put real secrets in GitHub.

# WeChat login
WECHAT_APPID=your_wechat_appid
WECHAT_APPSECRET=your_wechat_appsecret
TOKEN_SECRET=replace_with_a_long_random_secret

# OneNET device data
ONENET_PRODUCT_ID=your_onenet_product_id
ONENET_DEVICE_NAME=your_onenet_device_name
ONENET_ACCESS_KEY=your_onenet_access_key
ONENET_RESOURCE=products/your_onenet_product_id
ONENET_FIELD_MAP={"temp":"temperature","moi":"humidity","PH":"ph","EC":"ec"}

# Soil analysis AI, OpenAI-compatible API
AI_API_URL=https://api.deepseek.com/v1/chat/completions
AI_API_KEY=your_ai_api_key
AI_MODEL=deepseek-chat

# Vision AI for pest detection
VISION_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
VISION_API_KEY=your_vision_api_key
VISION_MODEL=glm-4v-flash
VISION_TEMPERATURE=0.2
VISION_MAX_TOKENS=900

# SMS login, optional
SMS_PROVIDER=tencent
TENCENTCLOUD_SECRET_ID=your_tencentcloud_secret_id
TENCENTCLOUD_SECRET_KEY=your_tencentcloud_secret_key
TENCENT_SMS_SDK_APP_ID=your_sms_sdk_app_id
TENCENT_SMS_SIGN_NAME=your_sms_sign_name
TENCENT_SMS_TEMPLATE_ID=your_sms_template_id
